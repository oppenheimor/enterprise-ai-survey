generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model SurveyLead {
  id          String   @id @default(cuid())
  companyName String
  contactName String
  email       String
  phone       String?
  goals       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
